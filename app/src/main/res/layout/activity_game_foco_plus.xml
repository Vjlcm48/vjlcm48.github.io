<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_mid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.5"
        android:orientation="vertical" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_topbar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.065" />


    <ImageView
        android:id="@+id/back_arrow"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:padding="12dp"
        android:contentDescription="@string/back"
        android:src="@drawable/ic_arrowback"
        app:layout_constraintTop_toBottomOf="@id/guideline_topbar"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tv_level"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/level_title"
        android:textStyle="bold"
        android:textSize="18sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:fontFamily="@font/gochi_hand"
        app:layout_constraintStart_toEndOf="@id/back_arrow"
        app:layout_constraintEnd_toStartOf="@id/guideline_mid"
        app:layout_constraintTop_toTopOf="@id/back_arrow"
        app:layout_constraintBottom_toBottomOf="@id/back_arrow"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"/>


    <TextView
        android:id="@+id/tv_score"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/score_label"
        android:textStyle="bold"
        android:textSize="18sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:fontFamily="@font/gochi_hand"
        app:layout_constraintStart_toStartOf="@id/guideline_mid"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/back_arrow"
        app:layout_constraintBottom_toBottomOf="@id/back_arrow"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"/>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/content_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/back_arrow"
        app:layout_constraintBottom_toTopOf="@id/home_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline_mid_inner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.5" />

            <ImageView
                android:id="@+id/icon_central"
                android:layout_width="98dp"
                android:layout_height="100dp"
                android:layout_marginTop="12dp"
                android:contentDescription="@string/app_logo"
                android:src="@drawable/sumamentelt"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <FrameLayout
                android:id="@+id/board_container"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/pizarra_background_foco"
                android:clickable="false"
                android:focusable="false"
                android:padding="16dp"
                app:layout_constraintTop_toBottomOf="@id/icon_central"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.90"
                app:layout_constraintDimensionRatio="8:4"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/tv_vamos"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="@string/vamos_text"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:alpha="0"
                    android:visibility="gone"
                    android:fontFamily="@font/gochi_hand"/>

                <LinearLayout
                    android:id="@+id/single_slot"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_single_exercise"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="42sp"
                        android:textColor="@android:color/white"
                        android:fontFamily="@font/gochi_hand"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/dual_slot"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_left_exercise"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:textSize="32sp"
                        android:textColor="@android:color/white"
                        android:fontFamily="@font/gochi_hand"/>

                    <TextView
                        android:id="@+id/tv_right_exercise"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:textSize="32sp"
                        android:textColor="@android:color/white"
                        android:fontFamily="@font/gochi_hand"/>

                    <ImageView
                        android:id="@+id/iv_board_left"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:padding="8dp"
                        android:contentDescription="@string/position_1"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/iv_board_right"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:padding="8dp"
                        android:contentDescription="@string/position_2"
                        android:visibility="gone" />


                </LinearLayout>
            </FrameLayout>

            <TextView
                android:id="@+id/chronometer_text_view"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:visibility="visible"
                android:text="@string/initial_time_format"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:textSize="24sp"
                android:ems="6"
                android:includeFontPadding="false"
                app:layout_constraintTop_toBottomOf="@id/board_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/guideline_mid_inner" />

            <TextView
                android:id="@+id/tv_errors_counter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:fontFamily="@font/gochi_hand"
                android:text="@string/errors_counter_default"
                android:textColor="?attr/colorOnBackground"
                android:textStyle="bold"
                android:textSize="24sp"
                app:layout_constraintTop_toBottomOf="@id/board_container"
                app:layout_constraintStart_toEndOf="@id/guideline_mid_inner"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBaseline_toBaselineOf="@id/chronometer_text_view"/>


            <ProgressBar
                android:id="@+id/time_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="10dp"
                android:progress="0"
                android:max="1000"
                android:indeterminate="false"
                android:progressTint="@color/red"
                app:layout_constraintTop_toBottomOf="@id/tv_errors_counter"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="6dp"/>


            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/answers_grid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:columnCount="3"
                app:rowCount="2"
                app:layout_constraintTop_toBottomOf="@id/time_progress"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_meta_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="64dp"
                        android:maxWidth="320dp"
                        android:background="@drawable/button_background"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/gochi_hand"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="14sp"
                        app:autoSizeMaxTextSize="30sp"
                        android:text="@string/position_1"
                        android:layout_gravity="center" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_meta_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="64dp"
                        android:maxWidth="320dp"
                        android:background="@drawable/button_background"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/gochi_hand"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="14sp"
                        app:autoSizeMaxTextSize="30sp"
                        android:text="@string/position_2"
                        android:layout_gravity="center" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_meta_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="64dp"
                        android:maxWidth="320dp"
                        android:background="@drawable/button_background"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/gochi_hand"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="14sp"
                        app:autoSizeMaxTextSize="30sp"
                        android:text="@string/position_3"
                        android:layout_gravity="center" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_meta_4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="64dp"
                        android:maxWidth="320dp"
                        android:background="@drawable/button_background"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/gochi_hand"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="14sp"
                        app:autoSizeMaxTextSize="30sp"
                        android:text="@string/position_4"
                        android:layout_gravity="center" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_meta_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="64dp"
                        android:maxWidth="320dp"
                        android:background="@drawable/button_background"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/gochi_hand"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="14sp"
                        app:autoSizeMaxTextSize="30sp"
                        android:text="@string/position_5"
                        android:layout_gravity="center" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_meta_none"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="64dp"
                        android:maxWidth="320dp"
                        android:background="@drawable/button_background"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/gochi_hand"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="14sp"
                        app:autoSizeMaxTextSize="30sp"
                        android:text="@string/answer_none"
                        android:layout_gravity="center" />
                </FrameLayout>

            </androidx.gridlayout.widget.GridLayout>

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/answers_grid_figures"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:columnCount="3"
                app:rowCount="2"
                app:layout_constraintTop_toBottomOf="@id/time_progress"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/iv_meta_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="64dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/button_background_lifetime"
                    android:scaleType="fitCenter"
                    android:padding="4dp"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1"
                    app:layout_gravity="fill"
                    android:contentDescription="@string/position_1" />

                <ImageView
                    android:id="@+id/iv_meta_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="64dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/button_background_lifetime"
                    android:scaleType="fitCenter"
                    android:padding="4dp"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1"
                    app:layout_gravity="fill"
                    android:contentDescription="@string/position_2" />

                <ImageView
                    android:id="@+id/iv_meta_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="64dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/button_background_lifetime"
                    android:scaleType="fitCenter"
                    android:padding="4dp"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1"
                    app:layout_gravity="fill"
                    android:contentDescription="@string/position_3" />

                <ImageView
                    android:id="@+id/iv_meta_4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="64dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/button_background_lifetime"
                    android:scaleType="fitCenter"
                    android:padding="4dp"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1"
                    app:layout_gravity="fill"
                    android:contentDescription="@string/position_4" />

                <ImageView
                    android:id="@+id/iv_meta_5"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="64dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/button_background_lifetime"
                    android:scaleType="fitCenter"
                    android:padding="4dp"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1"
                    app:layout_gravity="fill"
                    android:contentDescription="@string/position_5" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_meta_none_figures"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="64dp"
                    android:layout_margin="8dp"
                    android:background="@drawable/button_background_lifetime"
                    android:textColor="@android:color/black"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/gochi_hand"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="14sp"
                    app:autoSizeMaxTextSize="30sp"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1"
                    android:text="@string/answer_none" />
            </androidx.gridlayout.widget.GridLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <TextView
        android:id="@+id/home_button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="55dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:drawablePadding="6dp"
        android:focusable="true"
        android:fontFamily="@font/gochi_hand"
        android:gravity="center"
        android:minHeight="64dp"
        android:padding="12dp"
        android:text="@string/home_text"
        android:textColor="?attr/colorOnBackground"
        android:textSize="14sp"
        app:drawableTopCompat="@drawable/ic_inicio"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/calendar_button"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/calendar_button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="64dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:drawablePadding="6dp"
        android:focusable="true"
        android:gravity="center"
        android:padding="12dp"
        android:text="@string/calendar_text"
        android:textColor="?attr/colorOnBackground"
        android:textSize="14sp"
        android:fontFamily="@font/gochi_hand"
        app:drawableTopCompat="@drawable/ic_calendario"
        app:layout_constraintTop_toTopOf="@+id/home_button"
        app:layout_constraintEnd_toStartOf="@+id/statistics_button"
        app:layout_constraintStart_toEndOf="@+id/home_button" />

    <TextView
        android:id="@+id/statistics_button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="64dp"
        android:layout_marginEnd="24dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:drawablePadding="6dp"
        android:focusable="true"
        android:gravity="center"
        android:padding="12dp"
        android:text="@string/statistics_text"
        android:textColor="?attr/colorOnBackground"
        android:textSize="14sp"
        android:fontFamily="@font/gochi_hand"
        app:drawableTopCompat="@drawable/ic_estadisticas"
        app:layout_constraintTop_toTopOf="@+id/home_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/calendar_button" />

</androidx.constraintlayout.widget.ConstraintLayout>
