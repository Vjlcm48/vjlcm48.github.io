<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <FrameLayout
            android:id="@+id/frameLayout_condecoracion"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/img_condecoracion"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:contentDescription="@string/condecoracion_image"
                android:scaleType="fitCenter"
                tools:src="@drawable/ic_pin_invictus" />

            <View
                android:id="@+id/red_dot_small"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/red_dot_small"
                android:visibility="gone" />

        </FrameLayout>


        <TextView
            android:id="@+id/tv_condecoracion_fecha"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@android:color/black"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@+id/frameLayout_condecoracion"
            app:layout_constraintTop_toBottomOf="@+id/frameLayout_condecoracion"
            tools:text="Obtenido: 07/06/2025" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/frameLayout_condecoracion"
            app:layout_constraintTop_toTopOf="parent">

            <!-- FrameLayout para título con punto rojo -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tv_condecoracion_nombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/roboto_bold"
                    android:textColor="@android:color/black"
                    android:textSize="18sp"
                    tools:text="@string/pin_invictus" />

                <View
                    android:id="@+id/red_dot_titulo"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/red_dot_small"
                    android:visibility="gone" />

            </FrameLayout>

            <TextView
                android:id="@+id/tv_condecoracion_descripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@android:color/black"
                android:textSize="14sp"
                tools:text="@string/logro_pin_invictus" />

            <ImageView
                android:id="@+id/btn_share_condecoracion"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="@string/share"
                android:src="@drawable/ic_share"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/blue_primary_dark"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>