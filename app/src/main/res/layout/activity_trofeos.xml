<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue_primary">

    <!-- LOGO -->
    <ImageView
        android:id="@+id/app_logo"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginTop="38dp"
        android:alpha="0"
        android:contentDescription="@string/app_logo"
        android:src="@drawable/sumamentelt"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:alpha="1"
        tools:ignore="ImageContrastCheck"/>

    <!-- BOTÓN BACK -->
    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="18dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="fitCenter"
        android:contentDescription="@string/back"
        android:src="@drawable/ic_arrowback"
        android:alpha="0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/app_logo"
        tools:alpha="1" />

    <!-- BOTÓN CLOSE -->
    <ImageView
        android:id="@+id/btn_close"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="18dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="fitCenter"
        android:contentDescription="@string/close"
        android:src="@drawable/ic_close"
        android:alpha="0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/app_logo"
        tools:alpha="1" />

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/tv_titulo_trofeos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:fontFamily="@font/roboto_bold"
        android:text="@string/premio_titulo"
        android:textAlignment="center"
        android:textColor="@android:color/black"
        android:textSize="24sp"
        android:alpha="0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_back"
        tools:alpha="1" />

    <!-- SCROLL Y BOTONES -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_titulo_trofeos"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">


            <LinearLayout
                android:id="@+id/btn_mis_condecoraciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:background="@drawable/button_background_pro"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minHeight="65dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:alpha="0"
                tools:alpha="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mis_condecoraciones"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/mis_condecoraciones_red_dot"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/red_dot_big"
                    android:visibility="gone"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_pin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:background="@drawable/premio_boton_background"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minHeight="65dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:alpha="0"
                tools:alpha="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pin_reconocimiento"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_corona"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:background="@drawable/premio_boton_background"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minHeight="65dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:alpha="0"
                tools:alpha="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/corona_laureles"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Repite este patrón para los demás botones -->
            <LinearLayout
                android:id="@+id/btn_medalla"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:background="@drawable/premio_boton_background"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minHeight="65dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:alpha="0"
                tools:alpha="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/medalla"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_trofeo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:background="@drawable/premio_boton_background"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minHeight="65dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:alpha="0"
                tools:alpha="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/trofeo"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_top_10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:background="@drawable/premio_boton_background"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minHeight="65dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:alpha="0"
                tools:alpha="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/top_10"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_los_7_mejores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:background="@drawable/premio_boton_background"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minHeight="65dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:alpha="0"
                tools:alpha="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/los_7_mejores"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_los_5_mejores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:background="@drawable/premio_boton_background"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minHeight="65dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:alpha="0"
                tools:alpha="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/top5_ranking_integral"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_apex_supremus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:background="@drawable/premio_boton_background"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minHeight="65dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:alpha="0"
                tools:alpha="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/condecoracion_suprema"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
