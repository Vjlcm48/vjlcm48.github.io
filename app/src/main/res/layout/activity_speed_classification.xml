<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue_primary"
    android:padding="32dp"
    android:gravity="center">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/dialog_background"
        android:padding="24dp"
        android:layout_centerInParent="true"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/speed_classification_title"
                android:textColor="@android:color/black"
                android:textSize="18sp"
                android:fontFamily="@font/roboto_bold"
                android:gravity="center"
                android:layout_gravity="center_vertical" />

            <ImageView
                android:id="@+id/closeButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_close"
                android:contentDescription="@string/cerrar"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/select_game_speed"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btn_numeros_plus"
            android:layout_width="271dp"
            android:layout_height="59dp"
            android:background="@drawable/button_background"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_game_name_numeros_plus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/game_numeros_plus"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:fontFamily="@font/roboto_bold"
                android:gravity="center_vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/ic_reloj_numeros_plus"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/ic_reloj_numeros_plus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_reloj"
                android:contentDescription="@string/speed_ranking_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="16dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btn_deci_plus"
            android:layout_width="271dp"
            android:layout_height="59dp"
            android:background="@drawable/button_background_deci"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_game_name_deci_plus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/game_deci_plus"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:fontFamily="@font/roboto_bold"
                android:gravity="center_vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/ic_reloj_deci_plus"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/ic_reloj_deci_plus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_reloj"
                android:contentDescription="@string/speed_ranking_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="16dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btn_romas"
            android:layout_width="271dp"
            android:layout_height="59dp"
            android:background="@drawable/button_background_romas"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_game_name_romas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/game_romas"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:fontFamily="@font/roboto_bold"
                android:gravity="center_vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/ic_reloj_romas"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/ic_reloj_romas"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_reloj"
                android:contentDescription="@string/speed_ranking_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="16dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btn_alfa_numeros"
            android:layout_width="271dp"
            android:layout_height="59dp"
            android:background="@drawable/button_background_alfa_numeros"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_game_name_alfa_numeros"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/game_alfa_numeros"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:fontFamily="@font/roboto_bold"
                android:gravity="center_vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/ic_reloj_alfa_numeros"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/ic_reloj_alfa_numeros"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_reloj"
                android:contentDescription="@string/speed_ranking_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="16dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Botón SumaResta -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btn_sumaresta"
            android:layout_width="271dp"
            android:layout_height="59dp"
            android:background="@drawable/button_background_sumaresta"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_game_name_sumaresta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/game_sumaresta"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:fontFamily="@font/roboto_bold"
                android:gravity="center_vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/ic_reloj_sumaresta"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/ic_reloj_sumaresta"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_reloj"
                android:contentDescription="@string/speed_ranking_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="16dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btn_mas_plus"
            android:layout_width="271dp"
            android:layout_height="59dp"
            android:background="@drawable/button_background_mas"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_game_name_mas_plus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/game_mas_plus"
                android:textColor="@color/grey_light"
                android:textSize="20sp"
                android:fontFamily="@font/roboto_bold"
                android:gravity="center_vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/ic_reloj_mas_plus"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/ic_reloj_mas_plus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_reloj"
                android:contentDescription="@string/speed_ranking_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="16dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btn_genio_plus"
            android:layout_width="271dp"
            android:layout_height="59dp"
            android:background="@drawable/button_background_genio"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_game_name_genio_plus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/game_genio_plus"
                android:textColor="@color/blue_pressed"
                android:textSize="20sp"
                android:fontFamily="@font/roboto_bold"
                android:gravity="center_vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/ic_reloj_genio_plus"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:id="@+id/ic_reloj_genio_plus"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_reloj"
                android:contentDescription="@string/speed_ranking_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="16dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>
</RelativeLayout>
