<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/back_arrow"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="50dp"
        android:contentDescription="@string/back"
        android:src="@drawable/ic_arrowback"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_level"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:text="@string/level_title"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.25"
        app:layout_constraintStart_toEndOf="@id/back_arrow"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_score"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:text="@string/score_label"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@id/tv_level"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/icon_central"
        android:layout_width="98dp"
        android:layout_height="100dp"
        android:layout_marginTop="34dp"
        android:contentDescription="@string/app_logo"
        android:src="@drawable/sumamentelt"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/back_arrow" />

    <FrameLayout
        android:id="@+id/progress_ring_container"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:contentDescription="@string/progress_ring_description"
        app:layout_constraintWidth_percent="0.75"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toBottomOf="@id/icon_central"
        app:layout_constraintBottom_toTopOf="@id/home_icon"
        app:layout_constraintVertical_bias="0.25"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/blue_circle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="15dp"
            android:background="@drawable/blue_circle_drawable"
            android:layout_gravity="center" />

        <com.heptacreation.sumamente.ui.ProgressRingView
            android:id="@+id/progress_ring"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:indeterminate="false"
            app:indicatorSize="240dp"
            app:trackThickness="25dp"
            app:indicatorDirectionCircular="clockwise"
            app:indicatorInset="0dp"
            app:indicatorColor="@color/red_primary"
            app:trackColor="@android:color/darker_gray"
            android:layout_gravity="center" />

        <TextView
            android:id="@+id/tv_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="124sp"
            android:gravity="center"
            android:textColor="@android:color/black"
            android:layout_gravity="center"/>
    </FrameLayout>

    <TextView
        android:id="@+id/tv_vamos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="@string/vamos_text"
        android:gravity="center"
        android:textColor="@android:color/black"
        android:visibility="gone"
        android:padding="16dp"
        app:autoSizeTextType="uniform"
        app:autoSizeMinTextSize="24sp"
        app:autoSizeMaxTextSize="60sp"
        app:layout_constraintTop_toTopOf="@id/progress_ring_container"
        app:layout_constraintBottom_toBottomOf="@id/progress_ring_container"
        app:layout_constraintStart_toStartOf="@id/progress_ring_container"
        app:layout_constraintEnd_toEndOf="@id/progress_ring_container"/>

    <TextView
        android:id="@+id/tv_prompt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="45dp"
        android:text="@string/prompt_choose_correct_answer"
        android:textSize="25sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/icon_central"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/chronometer_text_view"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="30sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tv_prompt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/manual_input_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="70dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_prompt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/et_manual_answer"
            android:layout_width="150dp"
            android:layout_height="450dp"
            android:inputType="numberSigned"
            android:maxLength="3"
            android:hint="@string/enter_answer_hint"
            android:textSize="24sp"
            android:background="@drawable/input_field_background"
            android:padding="6dp"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:importantForAutofill="no"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_submit_answer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/button_background"
            android:text="@string/submit"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <androidx.gridlayout.widget.GridLayout
        android:id="@+id/answer_buttons_grid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="45dp"
        android:visibility="gone"
        app:columnCount="2"
        app:layout_constraintTop_toBottomOf="@id/tv_prompt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:rowCount="2">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_answer_1"
            android:layout_width="140dp"
            android:layout_height="100dp"
            android:layout_margin="12dp"
            app:layout_rowWeight="1"
            app:layout_columnWeight="1"
            android:background="@drawable/button_background"
            android:textColor="@android:color/white"
            android:textSize="30sp"
            android:textStyle="bold"
            android:text="@string/respuesta_1"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_answer_2"
            android:layout_width="140dp"
            android:layout_height="100dp"
            android:layout_margin="12dp"
            app:layout_rowWeight="1"
            app:layout_columnWeight="1"
            android:background="@drawable/button_background"
            android:textColor="@android:color/white"
            android:textSize="30sp"
            android:textStyle="bold"
            android:text="@string/respuesta_2"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_answer_3"
            android:layout_width="140dp"
            android:layout_height="100dp"
            android:layout_margin="12dp"
            app:layout_rowWeight="1"
            app:layout_columnWeight="1"
            android:background="@drawable/button_background"
            android:textColor="@android:color/white"
            android:textSize="30sp"
            android:textStyle="bold"
            android:text="@string/respuesta_3"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_answer_4"
            android:layout_width="140dp"
            android:layout_height="100dp"
            android:layout_margin="12dp"
            app:layout_rowWeight="1"
            app:layout_columnWeight="1"
            android:background="@drawable/button_background"
            android:textColor="@android:color/white"
            android:textSize="30sp"
            android:textStyle="bold"
            android:text="@string/respuesta_4"
            android:visibility="gone" />
    </androidx.gridlayout.widget.GridLayout>

    <ImageView
        android:id="@+id/home_icon"
        android:layout_width="35dp"
        android:layout_height="40dp"
        android:layout_marginStart="52dp"
        android:layout_marginBottom="80dp"
        android:contentDescription="@string/home"
        android:src="@drawable/ic_inicio"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_text"
        android:textSize="12sp"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/home_icon"
        app:layout_constraintStart_toStartOf="@id/home_icon"
        app:layout_constraintEnd_toEndOf="@id/home_icon" />

    <ImageView
        android:id="@+id/calendar_icon"
        android:layout_width="35dp"
        android:layout_height="40dp"
        android:layout_marginBottom="80dp"
        android:contentDescription="@string/calendar"
        android:src="@drawable/ic_calendario"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/statistics_icon"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@id/home_icon" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/calendar_text"
        android:textSize="12sp"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/calendar_icon"
        app:layout_constraintStart_toStartOf="@id/calendar_icon"
        app:layout_constraintEnd_toEndOf="@id/calendar_icon" />

    <ImageView
        android:id="@+id/statistics_icon"
        android:layout_width="35dp"
        android:layout_height="40dp"
        android:layout_marginEnd="52dp"
        android:layout_marginBottom="80dp"
        android:contentDescription="@string/statistics"
        android:src="@drawable/ic_estadisticas"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/statistics_text"
        android:textSize="12sp"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/statistics_icon"
        app:layout_constraintStart_toStartOf="@id/statistics_icon"
        app:layout_constraintEnd_toEndOf="@id/statistics_icon" />

</androidx.constraintlayout.widget.ConstraintLayout>
