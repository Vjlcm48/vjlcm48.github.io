<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/dialog_background"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:maxWidth="320dp">

    <TextView
        android:id="@+id/dialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/conflict_progress_title"
        android:textColor="?attr/colorOnBackground"


        android:textAlignment="center"
        android:textSize="20sp"
        android:fontFamily="@font/roboto_bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/dialogMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/conflict_progress_message"
        android:textColor="?attr/colorOnBackground"


        android:textAlignment="center"
        android:textSize="16sp"
        android:fontFamily="@font/roboto_regular"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRestoreCloud"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/button_background_avanzado"
            android:text="@string/btn_restore_cloud_progress"
            android:textColor="?attr/colorOnBackground"

            app:backgroundTint="@null"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnKeepLocal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/button_background"
            android:text="@string/btn_keep_local_progress"
            android:textColor="?attr/colorOnPrimary"

            app:backgroundTint="@null"/>
    </LinearLayout>
</LinearLayout>
