<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue_primary">

    <ImageView
        android:id="@+id/closeButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:contentDescription="@string/cerrar"
        android:src="@drawable/ic_close"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_reset_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:alpha="0"
        android:fontFamily="@font/roboto_bold"
        android:text="@string/select_game_to_reset"
        android:textAlignment="center"
        android:textColor="@android:color/black"
        android:textSize="26sp"
        android:maxLines="3"
        android:ellipsize="end"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <ScrollView
        android:id="@+id/reset_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tv_reset_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/layout_reset_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/dialog_background"
            android:paddingTop="32dp"
            android:paddingBottom="32dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:elevation="6dp">


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btn_numeros_plus"
                android:layout_width="match_parent"
                android:layout_height="59dp"
                android:layout_marginBottom="16dp"
                android:alpha="0"
                android:background="@drawable/button_background">

                <TextView
                    android:id="@+id/tv_game_name_numeros_plus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/game_numeros_plus"
                    android:textColor="@android:color/black"
                    android:textSize="20sp"
                    android:fontFamily="@font/roboto_bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginStart="16dp" />
                <ImageView
                    android:id="@+id/ic_reset_numeros_plus"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="@string/reset_progress"
                    android:src="@drawable/ic_reset"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />


            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btn_deci_plus"
                android:layout_width="match_parent"
                android:layout_height="59dp"
                android:layout_marginBottom="16dp"
                android:alpha="0"
                android:background="@drawable/button_background_deci">

                <TextView
                    android:id="@+id/tv_game_name_deci_plus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/game_deci_plus"
                    android:textColor="@android:color/black"
                    android:textSize="20sp"
                    android:fontFamily="@font/roboto_bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginStart="16dp" />

                <ImageView
                    android:id="@+id/ic_reset_deci_plus"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="@string/reset_progress"
                    android:src="@drawable/ic_reset"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btn_romas"
                android:layout_width="match_parent"
                android:layout_height="59dp"
                android:layout_marginBottom="16dp"
                android:alpha="0"
                android:background="@drawable/button_background_romas">

                <TextView
                    android:id="@+id/tv_game_name_romas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/game_romas"
                    android:textColor="@android:color/black"
                    android:textSize="20sp"
                    android:fontFamily="@font/roboto_bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginStart="16dp" />

                <ImageView
                    android:id="@+id/ic_reset_romas"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="@string/reset_progress"
                    android:src="@drawable/ic_reset"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btn_alfa_numeros"
                android:layout_width="match_parent"
                android:layout_height="59dp"
                android:layout_marginBottom="16dp"
                android:alpha="0"
                android:background="@drawable/button_background_alfa_numeros">

                <TextView
                    android:id="@+id/tv_game_name_alfa_numeros"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/game_alfa_numeros"
                    android:textColor="@android:color/black"
                    android:textSize="20sp"
                    android:fontFamily="@font/roboto_bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginStart="16dp" />

                <ImageView
                    android:id="@+id/ic_reset_alfa_numeros"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="@string/reset_progress"
                    android:src="@drawable/ic_reset"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btn_sumaresta"
                android:layout_width="match_parent"
                android:layout_height="59dp"
                android:layout_marginBottom="16dp"
                android:alpha="0"
                android:background="@drawable/button_background_sumaresta">

                <TextView
                    android:id="@+id/tv_game_name_sumaresta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/game_sumaresta"
                    android:textColor="@android:color/black"
                    android:textSize="20sp"
                    android:fontFamily="@font/roboto_bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginStart="16dp" />

                <ImageView
                    android:id="@+id/ic_reset_sumaresta"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="@string/reset_progress"
                    android:src="@drawable/ic_reset"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btn_mas_plus"
                android:layout_width="match_parent"
                android:layout_height="59dp"
                android:layout_marginBottom="16dp"
                android:alpha="0"
                android:background="@drawable/button_background_mas">

                <TextView
                    android:id="@+id/tv_game_name_mas_plus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/game_mas_plus"
                    android:textColor="@color/grey_light"
                    android:textSize="20sp"
                    android:fontFamily="@font/roboto_bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginStart="16dp" />

                <ImageView
                    android:id="@+id/ic_reset_mas_plus"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="@string/reset_progress"
                    android:src="@drawable/ic_reset"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btn_genio_plus"
                android:layout_width="match_parent"
                android:layout_height="59dp"
                android:alpha="0"
                android:background="@drawable/button_background_genio">

                <TextView
                    android:id="@+id/tv_game_name_genio_plus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/game_genio_plus"
                    android:textColor="@color/blue_pressed"
                    android:textSize="20sp"
                    android:fontFamily="@font/roboto_bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginStart="16dp" />

                <ImageView
                    android:id="@+id/ic_reset_genio_plus"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="@string/reset_progress"
                    android:src="@drawable/ic_reset"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
