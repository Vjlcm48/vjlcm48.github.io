<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@color/card_bg_dialog">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/embajador_sumamente"
                android:textAlignment="center"
                android:textColor="?attr/colorOnBackground"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/embajador_regla_1"
                android:textColor="?attr/colorOnBackground"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/embajador_regla_2"
                android:textColor="?attr/colorOnBackground"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/canje_opcion_1"
                android:textColor="?attr/colorOnBackground"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/canje_opcion_2"
                android:textColor="?attr/colorOnBackground"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/canje_opcion_3"
                android:textColor="?attr/colorOnBackground"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="16dp"/>


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/embajador_regla_control"
                android:textColor="?attr/colorOnBackground"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/embajador_regla_notificacion"
                android:textColor="?attr/colorOnBackground"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/embajador_regla_beneficio"
                android:textColor="?attr/colorOnBackground"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>


            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_entendido"
                android:layout_width="320dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_background"
                android:text="@string/entendido"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="24sp"/>

        </LinearLayout>
    </ScrollView>
</androidx.cardview.widget.CardView>