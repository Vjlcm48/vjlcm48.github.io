<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="UselessParent">

    <LinearLayout
        android:id="@+id/dialog_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/dialog_background_with_border"
        android:minWidth="320dp"
        android:padding="24dp">

        <TextView
            android:id="@+id/dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:breakStrategy="high_quality"
            android:hyphenationFrequency="full"
            android:text="@string/dialog_title"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <LinearLayout
            android:id="@+id/layout_seleccion_simple"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_seleccion_simple"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/button_background_mas"
                android:breakStrategy="high_quality"
                android:ellipsize="none"
                android:gravity="center"
                android:hyphenationFrequency="full"
                android:lineSpacingExtra="2dp"
                android:maxLines="3"
                android:minHeight="80dp"
                android:padding="20dp"
                android:text="@string/seleccion_simple"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="0dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/info_seleccion_simple"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@null"
                    android:contentDescription="@string/info_seleccion_simple"
                    android:src="@drawable/ic_help_circle" />

                <ImageView
                    android:id="@+id/check_seleccion_simple"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginTop="6dp"
                    android:alpha="0"
                    android:contentDescription="@string/check_seleccion_simple"
                    android:src="@drawable/ic_check_green" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <LinearLayout
            android:id="@+id/layout_escribe_respuesta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_escribe_respuesta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/button_background_mas"
                android:breakStrategy="high_quality"
                android:ellipsize="none"
                android:gravity="center"
                android:hyphenationFrequency="full"
                android:lineSpacingExtra="2dp"
                android:maxLines="3"
                android:minHeight="80dp"
                android:padding="20dp"
                android:text="@string/escribe_tu_respuesta"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="0dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/info_escribe_respuesta"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@null"
                    android:contentDescription="@string/info_escribe_respuesta"
                    android:src="@drawable/ic_help_circle" />

                <ImageView
                    android:id="@+id/check_escribe_respuesta"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginTop="6dp"
                    android:alpha="0"
                    android:contentDescription="@string/check_escribe_respuesta"
                    android:src="@drawable/ic_check_green" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="20dp" />

    </LinearLayout>

</FrameLayout>
