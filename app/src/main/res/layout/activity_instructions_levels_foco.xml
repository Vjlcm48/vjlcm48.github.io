<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?android:attr/colorBackground">

    <ImageView
        android:id="@+id/btn_close"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:contentDescription="@string/close"
        android:focusable="true"
        android:padding="12dp"
        android:src="@drawable/ic_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_game_name"
        android:layout_width="319dp"
        android:layout_height="62dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/gochi_hand"
        android:gravity="center"
        android:includeFontPadding="false"
        android:maxLines="2"
        android:text="@string/game_foco_plus"
        android:textColor="@color/blue_pressed"
        android:textStyle="bold"
        app:autoSizeMaxTextSize="32sp"
        app:autoSizeMinTextSize="24sp"
        app:autoSizeStepGranularity="1sp"
        app:autoSizeTextType="uniform"
        app:layout_constraintEnd_toStartOf="@id/btn_close"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/info_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_game_name">

        <TextView
            android:id="@+id/tv_difficulty"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/clickable_background"
            android:clickable="true"
            android:contentDescription="@string/change_difficulty"
            android:drawablePadding="4dp"
            android:focusable="true"
            android:fontFamily="@font/gochi_hand"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            android:maxLines="2"
            android:minHeight="48dp"
            android:paddingStart="8dp"
            android:paddingTop="8dp"
            android:paddingEnd="4dp"
            android:paddingBottom="8dp"
            android:textColor="?attr/colorOnBackground"
            android:maxWidth="160dp"
            app:autoSizeMaxTextSize="18sp"
            app:autoSizeMinTextSize="14sp"
            app:autoSizeStepGranularity="1sp"
            app:autoSizeTextType="uniform"
            app:drawableEndCompat="@drawable/ic_edit" />

        <TextView
            android:id="@+id/tv_score"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/gochi_hand"
            android:gravity="center_vertical|end"
            android:includeFontPadding="false"
            android:maxLines="2"
            android:minHeight="48dp"
            android:padding="8dp"
            android:textColor="?attr/colorFocoPlusScore"
            android:textStyle="bold"
            app:autoSizeMaxTextSize="30sp"
            app:autoSizeMinTextSize="18sp"
            app:autoSizeStepGranularity="1sp"
            app:autoSizeTextType="uniform" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/level_selection_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/info_bar">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/level_selector_button"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:background="@drawable/level_button_background"
            android:fontFamily="@font/gochi_hand"
            android:gravity="center"
            android:minHeight="84dp"
            android:padding="18dp"
            android:text="@string/select_level_button"
            android:textColor="@android:color/white"
            android:textSize="27sp"
            android:maxWidth="180dp" />

        <TextView
            android:id="@+id/tv_level_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/gochi_hand"
            android:gravity="center_vertical|end"
            android:includeFontPadding="false"
            android:maxLines="2"
            android:minHeight="84dp"
            android:padding="12dp"
            android:text="@string/level_indicator_default"
            android:textColor="?attr/colorOnBackground"
            android:textSize="30sp"
            android:textStyle="bold" />

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/level_dropdown_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/dialog_background_with_border"
        android:elevation="4dp"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/level_selection_bar">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/level_dropdown_scroll"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginBottom="16dp"
            android:fadeScrollbars="false"
            android:fillViewport="false"
            android:scrollbars="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/level_buttons_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp" />

        </androidx.core.widget.NestedScrollView>

        <View
            android:id="@+id/dropdown_gradient_view"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:alpha="0"
            android:background="@drawable/gradient_fade_bottom"
            app:layout_constraintBottom_toBottomOf="@id/level_dropdown_scroll"
            app:layout_constraintEnd_toEndOf="@id/level_dropdown_scroll"
            app:layout_constraintStart_toStartOf="@id/level_dropdown_scroll" />

        <ImageView
            android:id="@+id/dropdown_arrow_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginBottom="8dp"
            android:alpha="0"
            android:contentDescription="@string/scroll_view_description"
            android:src="@drawable/ic_arrow_down"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:tint="@color/blue_primary" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/instructions_scroll_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:fadeScrollbars="false"
        android:fillViewport="true"
        android:scrollbars="vertical"
        app:layout_constraintBottom_toTopOf="@id/btn_start"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/level_selection_bar">

        <TextView
            android:id="@+id/tv_instructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/gochi_hand"
            android:gravity="center"
            android:lineSpacingExtra="6dp"
            android:padding="24dp"
            android:textColor="?attr/colorOnBackground"
            android:textSize="27sp" />

    </androidx.core.widget.NestedScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="75dp"
        android:background="@drawable/button_background_foco"
        android:enabled="false"
        android:fontFamily="@font/gochi_hand"
        android:maxWidth="320dp"
        android:paddingStart="72dp"
        android:paddingTop="18dp"
        android:paddingEnd="72dp"
        android:paddingBottom="18dp"
        android:text="@string/start_button_text"
        android:textColor="@android:color/white"
        android:textSize="36sp"
        android:textStyle="bold"
        android:singleLine="true"
        android:ellipsize="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>