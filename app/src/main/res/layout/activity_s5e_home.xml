<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/s5e_surface"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:src="@drawable/ic_s5e_logo"
        android:contentDescription="@string/app_name_s5e"
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:tint="@color/s5e_primary" />

    <TextView
        android:text="@string/app_name_s5e"
        android:textColor="@color/s5e_onSurface"
        android:textStyle="bold"
        android:textSize="24sp"
        android:layout_marginTop="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <ImageButton
        android:id="@+id/btnNewGame"
        android:src="@drawable/ic_new_game"
        android:backgroundTint="@color/s5e_primary"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/new_game_button"
        android:layout_marginTop="24dp"
        android:padding="16dp"
        android:layout_width="72dp"
        android:layout_height="72dp"/>

    <TextView
        android:text="@string/new_game"
        android:textColor="@color/s5e_onSurface"
        android:layout_marginTop="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
</LinearLayout>
