<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ImageView
        android:id="@+id/icon_central"
        android:layout_width="171dp"
        android:layout_height="134dp"
        android:layout_marginTop="144dp"
        android:contentDescription="@string/app_logo"
        android:src="@drawable/sumamentelt"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_sumamente_title"
        android:layout_width="304dp"
        android:layout_height="78dp"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/roboto_bold"
        android:text="@string/notification_app_name"
        android:textAlignment="center"
        android:textColor="@android:color/black"
        android:textSize="38sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.487"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/icon_central" />

    <TextView
        android:id="@+id/profile_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_marginStart="20dp"
        android:fontFamily="@font/roboto_bold"
        android:gravity="center_vertical"
        android:drawablePadding="8dp"
        android:padding="8dp"
        android:minWidth="48dp"
        android:minHeight="48dp"
        android:text="@string/username"
        android:textColor="@android:color/black"
        android:textSize="14sp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 3.1. Container para trophy_icon con punto rojo -->
    <FrameLayout
        android:id="@+id/trophy_container"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="108dp"
        android:layout_marginTop="40dp"
        app:layout_constraintStart_toEndOf="@id/profile_text"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/trophy_icon"
            android:layout_width="35dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:contentDescription="@string/trophy"
            android:src="@drawable/ic_trofeo" />


        <View
            android:id="@+id/trophy_red_dot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="2dp"
            android:background="@drawable/red_dot_big"
            android:visibility="gone" />

    </FrameLayout>

    <ImageView
        android:id="@+id/settings_icon"
        android:layout_width="35dp"
        android:layout_height="40dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="28dp"
        android:contentDescription="@string/settings"
        android:src="@drawable/ic_configuracion"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/new_game_button"
        android:layout_width="271dp"
        android:layout_height="59dp"
        android:layout_marginBottom="100dp"
        android:background="@drawable/button_background"
        android:fontFamily="@font/roboto_bold"
        android:text="@string/new_game"
        android:textColor="@android:color/black"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/home_icon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/home_icon"
        android:layout_width="35dp"
        android:layout_height="40dp"
        android:layout_marginStart="36dp"
        android:layout_marginBottom="44dp"
        android:contentDescription="@string/home"
        android:src="@drawable/ic_inicio"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/home_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/home_text"
        android:textColor="@android:color/black"
        android:textSize="12sp"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/home_icon"
        app:layout_constraintStart_toStartOf="@id/home_icon"
        app:layout_constraintEnd_toEndOf="@id/home_icon" />

    <ImageView
        android:id="@+id/calendar_icon"
        android:layout_width="35dp"
        android:layout_height="40dp"
        android:layout_marginBottom="44dp"
        android:contentDescription="@string/calendar"
        android:src="@drawable/ic_calendario"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/statistics_icon"
        app:layout_constraintHorizontal_bias="0.516"
        app:layout_constraintStart_toEndOf="@id/home_icon" />

    <TextView
        android:id="@+id/calendar_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/calendar_text"
        android:textColor="@android:color/black"
        android:textSize="12sp"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/calendar_icon"
        app:layout_constraintStart_toStartOf="@id/calendar_icon"
        app:layout_constraintEnd_toEndOf="@id/calendar_icon" />

    <ImageView
        android:id="@+id/statistics_icon"
        android:layout_width="35dp"
        android:layout_height="40dp"
        android:layout_marginEnd="44dp"
        android:layout_marginBottom="44dp"
        android:contentDescription="@string/statistics"
        android:src="@drawable/ic_estadisticas"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/statistics_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/statistics_text"
        android:textColor="@android:color/black"
        android:textSize="12sp"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/statistics_icon"
        app:layout_constraintStart_toStartOf="@id/statistics_icon"
        app:layout_constraintEnd_toEndOf="@id/statistics_icon" />

</androidx.constraintlayout.widget.ConstraintLayout>
