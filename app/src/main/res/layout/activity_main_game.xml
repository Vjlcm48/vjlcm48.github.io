<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:paddingTop="50dp"
    android:paddingBottom="32dp">

        <TextView
            android:id="@+id/profile_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:clickable="true"
            android:drawablePadding="8dp"
            android:focusable="true"
            android:fontFamily="@font/roboto_bold"
            android:gravity="center_vertical"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:padding="8dp"
            android:text="@string/username"
            android:textColor="?attr/colorOnBackground"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <FrameLayout
            android:id="@+id/trophy_container"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:layout_constraintEnd_toStartOf="@+id/settings_icon"
            app:layout_constraintStart_toEndOf="@id/profile_text"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/trophy_icon"
                android:layout_width="35dp"
                android:layout_height="37dp"
                android:layout_gravity="center"
                android:contentDescription="@string/trophy"
                android:src="@drawable/ic_trofeo" />

            <View
                android:id="@+id/trophy_red_dot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/red_dot_big"
                android:visibility="gone" />
        </FrameLayout>

    <FrameLayout
        android:id="@+id/settings_icon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/settings_icon_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"
            android:contentDescription="@string/settings"
            android:src="@drawable/ic_configuracion" />

        <View
            android:id="@+id/messages_red_dot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="2dp"
            android:background="@drawable/red_dot_big"
            android:visibility="gone" />
    </FrameLayout>


    <ImageView
            android:id="@+id/icon_central"
            android:layout_width="171dp"
            android:layout_height="134dp"
            android:contentDescription="@string/app_logo"
            android:src="@drawable/sumamentelt"
            app:layout_constraintBottom_toTopOf="@+id/tv_sumamente_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/profile_text"
            app:layout_constraintVertical_chainStyle="packed"
            app:layout_constraintVertical_bias="0.4"/>

        <TextView
            android:id="@+id/tv_sumamente_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/roboto_bold"
            android:text="@string/notification_app_name"
            android:textAlignment="center"
            android:textColor="?attr/colorOnBackground"
            android:textSize="38sp"
            app:layout_constraintBottom_toTopOf="@+id/new_game_button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/icon_central" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/new_game_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/button_background"
            android:elevation="24dp"
            android:fontFamily="@font/roboto_bold"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="@string/new_game"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            app:layout_constraintBottom_toTopOf="@+id/home_button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_sumamente_title"
            app:layout_constraintWidth_max="320dp" />

        <TextView
            android:id="@+id/home_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="32dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:drawablePadding="4dp"
            android:focusable="true"
            android:gravity="center"
            android:padding="8dp"
            android:text="@string/home_text"
            android:textColor="?attr/colorOnBackground"
            android:textSize="12sp"
            app:drawableTopCompat="@drawable/ic_inicio"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/calendar_button"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/calendar_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:drawablePadding="4dp"
            android:focusable="true"
            android:gravity="center"
            android:padding="8dp"
            android:text="@string/calendar_text"
            android:textColor="?attr/colorOnBackground"
            android:textSize="12sp"
            app:drawableTopCompat="@drawable/ic_calendario"
            app:layout_constraintTop_toTopOf="@+id/home_button"
            app:layout_constraintEnd_toStartOf="@+id/statistics_button"
            app:layout_constraintStart_toEndOf="@+id/home_button" />

        <TextView
            android:id="@+id/statistics_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:drawablePadding="4dp"
            android:focusable="true"
            android:gravity="center"
            android:padding="8dp"
            android:text="@string/statistics_text"
            android:textColor="?attr/colorOnBackground"
            android:textSize="12sp"
            app:drawableTopCompat="@drawable/ic_estadisticas"
            app:layout_constraintTop_toTopOf="@+id/home_button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/calendar_button" />

    <FrameLayout
        android:id="@+id/welcome_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        android:elevation="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/welcome_confetti"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.7"
        app:lottie_fileName="confetti_animation.json"
        app:lottie_loop="true"
        app:lottie_autoPlay="true"
        android:scaleType="centerCrop" />

        <View
            android:id="@+id/welcome_scrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:background="@android:color/transparent" />

        <RelativeLayout
        android:id="@+id/welcome_modal_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="320dp"
        android:minHeight="360dp"
        android:layout_gravity="center"
        android:background="@drawable/dialog_background_welcome"
        android:elevation="32dp"
        android:padding="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:maxWidth="360dp">

        <ImageView
            android:id="@+id/welcome_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="8dp"
            android:contentDescription="@string/cerrar"
            android:src="@drawable/ic_close"
            android:clickable="true"
            android:focusable="true" />


        <TextView
            android:id="@+id/welcome_message_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/welcome_close"
            android:layout_marginTop="12dp"
            android:gravity="center_horizontal"
            android:maxWidth="320dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="@string/welcome_message"
            android:textColor="?attr/colorOnBackground"
            android:textSize="24sp"
            android:fontFamily="@font/roboto_bold" />
    </RelativeLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
