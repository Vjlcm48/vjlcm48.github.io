<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue_primary">

    <androidx.cardview.widget.CardView
        android:layout_width="355dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@android:color/white"
        app:cardCornerRadius="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:id="@+id/btn_close"
                android:layout_width="27dp"
                android:layout_height="27dp"
                android:layout_gravity="end"
                android:contentDescription="@string/close_button_description"
                android:src="@drawable/ic_close" />

            <RelativeLayout
                android:id="@+id/info_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/tv_game_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:gravity="center"
                    android:textColor="@color/red_primary"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:includeFontPadding="false"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="18sp"
                    app:autoSizeMaxTextSize="28sp"
                    app:autoSizeStepGranularity="1sp" />

                <TextView
                    android:id="@+id/tv_difficulty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_game_name"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/tv_score"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/clickable_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:drawablePadding="4dp"
                    android:minHeight="48dp"
                    android:minWidth="110dp"
                    android:padding="8dp"
                    android:textColor="@android:color/black"
                    android:maxLines="4"
                    android:includeFontPadding="false"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="14sp"
                    app:autoSizeMaxTextSize="18sp"
                    app:autoSizeStepGranularity="1sp"
                    app:drawableEndCompat="@drawable/ic_edit"
                    android:contentDescription="@string/change_difficulty" />

                <TextView
                    android:id="@+id/tv_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_game_name"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical|end"
                    android:minHeight="48dp"
                    android:padding="8dp"
                    android:textColor="@android:color/black"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:includeFontPadding="false"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="14sp"
                    app:autoSizeMaxTextSize="20sp"
                    app:autoSizeStepGranularity="1sp" />
            </RelativeLayout>

            <ScrollView
                android:id="@+id/instructions_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="false"
                android:fadeScrollbars="false"
                android:scrollbars="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_level"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:gravity="center"
                        android:textColor="@android:color/black"
                        android:textSize="33sp"
                        android:textStyle="bold"
                        android:alpha="0" />

                    <TextView
                        android:id="@+id/tv_letter_conversion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/blue_primary_darker"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:alpha="0"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/tv_instructions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:textColor="@android:color/black"
                        android:textSize="24sp"
                        android:alpha="0" />

                    <TextView
                        android:id="@+id/tv_repeated_numbers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:textColor="@android:color/black"
                        android:textSize="21sp"
                        android:alpha="0" />

                    <TextView
                        android:id="@+id/tv_negative_numbers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:textColor="@android:color/black"
                        android:textSize="21sp"
                        android:alpha="0" />

                    <TextView
                        android:id="@+id/tv_time_limit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@android:color/black"
                        android:textSize="21sp"
                        android:alpha="0" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_start"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/button_background_alfa_numeros"
                        android:text="@string/start_button_text"
                        android:textColor="@android:color/black"
                        android:textSize="24sp"
                        android:paddingStart="40dp"
                        android:paddingEnd="40dp"
                        android:alpha="0"
                        android:scaleX="0"
                        android:scaleY="0" />
                </LinearLayout>
            </ScrollView>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>
