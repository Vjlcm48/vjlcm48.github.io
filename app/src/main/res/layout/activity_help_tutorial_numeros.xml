<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_instructions_numeros"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blue_hovered">

    <TextView
        android:id="@+id/tv_welcome_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="33sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="170dp" />

    <TextView
        android:id="@+id/tv_game_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="33sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/blue_pressed"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_welcome_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp" />


    <TextView
        android:id="@+id/tv_step_intro_part_a"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tutorial_step_intro_part_a"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_game_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <TextView
        android:id="@+id/tv_step_intro_part_b"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tutorial_step_intro_part_b"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnPrimary"

        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_step_intro_part_a"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/tv_step_one"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tutorial_step_one"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_instruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/escoge_tu_modo_de_respuesta"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnBackground"


        android:gravity="center"
        android:layout_marginTop="150dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_welcome_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/layout_dialog_modes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/dialog_background"
        android:visibility="gone"
        android:padding="16dp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <include
            layout="@layout/response_mode_dialog"/>
    </LinearLayout>


    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottie_hand_chrono"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:visibility="gone"
        app:lottie_autoPlay="false"
        app:lottie_loop="false"
        app:lottie_fileName="handchrono_animation.json"
        app:layout_constraintEnd_toStartOf="@+id/tv_chronometer_demo"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="@+id/tv_chronometer_demo"
        android:layout_marginBottom="0dp"
        android:layout_marginTop="-30dp"/>


    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottie_hand_answer"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:visibility="gone"
        app:lottie_autoPlay="false"
        app:lottie_loop="false"
        app:lottie_fileName="handanswer_animation.json"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <FrameLayout
        android:id="@+id/circle_view"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:visibility="gone"
        android:background="@drawable/circle_background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.heptacreation.sumamente.ui.ProgressRingView
            android:id="@+id/progress_ring"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:indeterminate="false"
            app:indicatorSize="240dp"
            app:trackThickness="25dp"
            app:indicatorDirectionCircular="clockwise"
            app:indicatorInset="0dp"
            app:indicatorColor="@color/red_primary"
            app:trackColor="@android:color/darker_gray"
            android:layout_gravity="center" />

        <TextView
            android:id="@+id/tv_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="?attr/colorOnBackground"


            android:textSize="124sp"
            android:layout_gravity="center" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_vamos_instructions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/vamos_text"
        android:textSize="50sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/circle_view"
        app:layout_constraintBottom_toBottomOf="@id/circle_view"
        app:layout_constraintStart_toStartOf="@id/circle_view"
        app:layout_constraintEnd_toEndOf="@id/circle_view"/>

    <LinearLayout
        android:id="@+id/layout_numbers_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/circle_view"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_chronometer_demo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/default_chronometer"
        android:textSize="30sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/layout_answer_buttons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="200dp"
        android:layout_marginBottom="8dp" />

    <GridLayout
        android:id="@+id/layout_answer_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:alignmentMode="alignMargins"
        android:gravity="center"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/tv_chronometer_demo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_answer_1_demo"
            android:layout_width="140dp"
            android:layout_height="100dp"
            android:layout_margin="12dp"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary"

            android:textSize="30sp"
            android:textStyle="bold"
            android:text="@string/answer_option_1"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_answer_2_demo"
            android:layout_width="140dp"
            android:layout_height="100dp"
            android:layout_margin="12dp"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary"

            android:textSize="30sp"
            android:textStyle="bold"
            android:text="@string/answer_option_2"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_answer_3_demo"
            android:layout_width="140dp"
            android:layout_height="100dp"
            android:layout_margin="12dp"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary"

            android:textSize="30sp"
            android:textStyle="bold"
            android:text="@string/answer_option_3"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_answer_4_demo"
            android:layout_width="140dp"
            android:layout_height="100dp"
            android:layout_margin="12dp"
            android:background="@drawable/button_background"
            android:textColor="?attr/colorOnPrimary"

            android:textSize="30sp"
            android:textStyle="bold"
            android:text="@string/answer_option_4"
            android:visibility="gone" />
    </GridLayout>


    <TextView
        android:id="@+id/tv_step_two"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tutorial_step_two"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottie_confetti"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:visibility="gone"
        app:lottie_autoPlay="false"
        app:lottie_loop="false"
        app:lottie_fileName="confetti_animation.json"
        app:layout_constraintBottom_toTopOf="@id/tv_final_message"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_final_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/perfecto"
        android:textSize="30sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/lottie_confetti"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5"/>

    <TextView
        android:id="@+id/tv_final_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tiempo_empleado"
        android:textSize="24sp"
        android:visibility="gone"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_final_message"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_final_points"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/puntos_obtenidos"
        android:textSize="24sp"
        android:visibility="gone"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_final_time"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/iv_star"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_star_numeros"
        android:contentDescription="@string/star_icon"
        android:visibility="gone"
        android:layout_marginTop="1dp"
        app:layout_constraintTop_toTopOf="@id/tv_final_points"
        app:layout_constraintStart_toEndOf="@id/tv_final_points"/>

    <!-- Botón JUGAR (antes ENTENDIDO) -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_play"
        android:layout_width="200dp"
        android:layout_height="70dp"
        android:text="@string/jugar"
        android:textSize="24sp"
        android:background="@drawable/button_background"
        android:textColor="?attr/colorOnPrimary"

        android:visibility="gone"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/btn_repeat"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Nuevo botón REPETIR -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_repeat"
        android:layout_width="200dp"
        android:layout_height="70dp"
        android:text="@string/repetir"
        android:textSize="24sp"
        android:background="@drawable/button_background"
        android:textColor="?attr/colorOnPrimary"

        android:visibility="gone"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/btn_close_instructions"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_close"
        android:contentDescription="@string/cerrar"
        android:visibility="gone"
        android:padding="8dp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <TextView
        android:id="@+id/tv_step_three_part_one"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tutorial_step_three_part_one"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="200dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_step_three_part_two"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tutorial_step_three_part_two"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="160dp"
        app:layout_constraintTop_toBottomOf="@id/tv_step_three_part_one"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_result_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tutorial_result_message"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_closing_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tutorial_closing_message"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>