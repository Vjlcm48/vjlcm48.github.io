<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:paddingBottom="40dp"
    android:background="?android:attr/colorBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/screen_padding">

        <FrameLayout
            android:id="@+id/frame_condecoracion"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintWidth_percent="0.8"
            app:layout_constraintHeight_percent="0.45">

            <ImageView
                android:id="@+id/img_condecoracion"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:contentDescription="@string/condecoracion_image" />

            <TextView
                android:id="@+id/tv_condecoracion_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="@dimen/content_gap_small"
                android:background="@drawable/circle_background"
                android:fontFamily="@font/roboto_bold"
                android:gravity="center"
                android:minWidth="@dimen/badge_min"
                android:minHeight="@dimen/badge_min"
                android:textColor="?attr/colorOnPrimary"

                android:textSize="@dimen/badge_text" />

        </FrameLayout>

        <TextView
            android:id="@+id/tv_condecoracion_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_gap_large"
            android:layout_marginStart="@dimen/content_gap_small"
            android:layout_marginEnd="@dimen/content_gap_small"
            android:fontFamily="@font/roboto_bold"
            android:textAlignment="center"
            android:textColor="?attr/colorOnBackground"


            android:textSize="@dimen/text_name"
            android:ellipsize="end"
            android:scrollHorizontally="false"
            android:singleLine="false"
            app:layout_constraintTop_toBottomOf="@id/frame_condecoracion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_condecoracion_meaning" />

        <TextView
            android:id="@+id/tv_condecoracion_meaning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_gap_small"
            android:layout_marginStart="@dimen/content_gap_small"
            android:layout_marginEnd="@dimen/content_gap_small"
            android:layout_marginBottom="@dimen/content_gap_large"
            android:fontFamily="@font/roboto_bold"
            android:textAlignment="center"
            android:textColor="@color/gray"
            android:textSize="@dimen/text_meaning"
            android:ellipsize="end"
            android:scrollHorizontally="false"
            android:singleLine="false"
            app:layout_constraintTop_toBottomOf="@id/tv_condecoracion_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>