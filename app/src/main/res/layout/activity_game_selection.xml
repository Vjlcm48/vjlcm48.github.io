            <RelativeLayout
                android:id="@+id/btn_mas_plus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="59dp"
                android:background="@drawable/button_background_mas"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tv_game_name_mas_plus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@id/tv_points_mas_plus"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="12dp"
                    android:text="@string/game_mas_plus"
                    android:textSize="20sp"
                    android:fontFamily="@font/roboto_bold"
                    android:textColor="@color/grey_light"
                    android:includeFontPadding="false"
                    android:maxLines="3"
                    android:breakStrategy="simple"
                    android:hyphenationFrequency="none"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_points_mas_plus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="16dp"
                    android:text="@string/default_score"
                    android:textSize="20sp"
                    android:fontFamily="@font/roboto_bold"
                    android:textColor="?attr/colorOnPrimary"

                    android:drawablePadding="4dp"
                    android:includeFontPadding="false"
                    android:visibility="gone"
                    app:drawableStartCompat="@drawable/ic_star"
