            </RelativeLayout>


            <RelativeLayout
                android:id="@+id/btn_sumaresta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="59dp"
                android:background="@drawable/button_background_sumaresta"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tv_game_name_sumaresta"
                    android:layout_width="match_parent"
