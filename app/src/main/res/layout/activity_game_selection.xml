                    android:paddingStart="8dp"
                    android:paddingEnd="16dp"
                    android:text="@string/default_score"
                    android:textSize="20sp"
                    android:fontFamily="@font/roboto_bold"
                    android:textColor="?attr/colorOnPrimary"

                    android:drawablePadding="4dp"
                    android:includeFontPadding="false"
                    android:visibility="gone"
                    app:drawableStartCompat="@drawable/ic_star"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="18sp"
                    app:autoSizeMaxTextSize="20sp"
                    app:autoSizeStepGranularity="1sp" />
            </RelativeLayout>


            <RelativeLayout
                android:id="@+id/btn_alfa_numeros"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="59dp"
                android:background="@drawable/button_background_alfa_numeros"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tv_game_name_alfa_numeros"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@id/tv_points_alfa_numeros"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="12dp"
                    android:text="@string/game_alfa_numeros"
                    android:textSize="20sp"
                    android:fontFamily="@font/roboto_bold"
                    android:textColor="?attr/colorOnBackground"


                    android:includeFontPadding="false"
                    android:maxLines="3"
                    android:breakStrategy="simple"
