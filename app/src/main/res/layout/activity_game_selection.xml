<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackgroundSpecial"
    android:paddingTop="50dp"
    android:paddingBottom="32dp">

    <ImageView
        android:id="@+id/closeButton"
        android:layout_width="48dp"
        android:layout_height="48dp"

        android:layout_marginEnd="24dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:contentDescription="@string/cerrar"
        android:focusable="true"
        android:src="@drawable/ic_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_select_game_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"

        android:alpha="0"
        android:fontFamily="@font/roboto_bold"
        android:text="@string/select_a_game"
        android:textAlignment="center"
        android:textColor="?attr/colorOnBackground"


        android:textSize="26sp"
        app:layout_constraintEnd_toStartOf="@+id/closeButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/game_selection_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="40dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tv_select_game_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/layout_game_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/dialog_background"
            android:paddingTop="32dp"
            android:paddingBottom="32dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:elevation="6dp">

        <RelativeLayout
            android:id="@+id/btn_progreso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="59dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/button_background_progreso"
            android:layout_marginBottom="16dp"
            android:contentDescription="@string/cd_my_progress"
            android:elevation="7dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="16dp"
                android:layout_toStartOf="@id/icon_graph_progreso"
                android:fontFamily="@font/roboto_bold"
                android:text="@string/my_progress"
                android:textColor="?attr/colorOnBackground"

                android:textSize="20sp" />

            <ImageView
                android:id="@+id/icon_graph_progreso"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                android:layout_toStartOf="@id/tv_percentage_progreso"
                android:contentDescription="@string/graph_icon"
                android:src="@drawable/ic_graph"
                android:visibility="visible" />

            <TextView
                android:id="@+id/tv_percentage_progreso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:fontFamily="@font/roboto_bold"
                android:text="@string/default_percentage"
                android:textColor="@color/blue_primary_dark"
                android:textSize="20sp" />
        </RelativeLayout>

            <RelativeLayout
                android:id="@+id/btn_numeros_plus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="59dp"
                android:background="@drawable/button_background"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tv_game_name_numeros_plus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@id/tv_points_numeros_plus"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="12dp"
                    android:text="@string/game_numeros_plus"
                    android:textSize="20sp"
                    android:fontFamily="@font/roboto_bold"
                    android:textColor="?attr/colorOnPrimary"

                    android:includeFontPadding="false"
                    android:maxLines="3"
                    android:breakStrategy="simple"
                    android:hyphenationFrequency="none"
                    android:ellipsize="end" />


                <TextView
                    android:id="@+id/tv_points_numeros_plus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="16dp"
                    android:text="@string/default_score"
                    android:textSize="20sp"
                    android:fontFamily="@font/roboto_bold"
                    android:textColor="?attr/colorOnPrimary"

                    android:drawablePadding="4dp"
                    android:includeFontPadding="false"
                    android:visibility="gone"
                    app:drawableStartCompat="@drawable/ic_star"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="18sp"
                    app:autoSizeMaxTextSize="20sp"
                    app:autoSizeStepGranularity="1sp" />
            </RelativeLayout>


            <RelativeLayout
                android:id="@+id/btn_deci_plus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="59dp"
                android:background="@drawable/button_background_deci"
                android:layout_marginBottom="16dp">

