            </RelativeLayout>


            <RelativeLayout
                android:id="@+id/btn_genio_plus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="59dp"
                android:background="@drawable/button_background_genio"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tv_game_name_genio_plus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@id/tv_points_genio_plus"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="12dp"
                    android:text="@string/game_genio_plus"
                    android:textSize="20sp"
                    android:fontFamily="@font/roboto_bold"
                    android:textColor="@color/blue_pressed"
                    android:includeFontPadding="false"
                    android:maxLines="3"
