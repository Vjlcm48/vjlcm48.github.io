<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="512"
    android:viewportHeight="512">

    <group
        android:scaleX="0.94"
        android:scaleY="0.94"
        android:translateX="-12"
        android:translateY="1">

        <!-- Sombra exterior de la estrella -->
        <group
            android:translateX="261"
            android:translateY="261"
            android:scaleX="13.87"
            android:scaleY="13.87">
            <path
                android:pathData="M0,-20 L19.5,4.5 L-8.7,18 L-15.6,-12.5 L15.6,-12.5 L8.7,18 L-19.5,4.5 Z"
                android:fillColor="#1A000000"
                android:fillAlpha="0.25"/>
        </group>

        <!-- Estrella principal con gradiente reforzado -->
        <group
            android:translateX="295"
            android:translateY="285"
            android:scaleX="13.87"
            android:scaleY="13.87">
            <path
                android:pathData="M0,-20 L19.5,4.5 L-8.7,18 L-15.6,-12.5 L15.6,-12.5 L8.7,18 L-19.5,4.5 Z">
                <aapt:attr name="android:fillColor">
                    <gradient
                        android:type="linear"
                        android:angle="135">
                        <item android:offset="0.0" android:color="#FF0A1C4E" />
                        <item android:offset="0.7" android:color="#FF053FA6" />
                        <item android:offset="1.0" android:color="#FF002060" />
                    </gradient>
                </aapt:attr>
            </path>
            <!--
                Cambio: Reducimos la escala interna del fondo claro
                de 0.85 a 0.74 (~15% más grueso el borde azul hacia adentro)
            -->
            <group
                android:scaleX="0.77"
                android:scaleY="0.77">
                <path
                    android:pathData="M0,-20 L19.5,4.5 L-8.7,18 L-15.6,-12.5 L15.6,-12.5 L8.7,18 L-19.5,4.5 Z"
                    android:fillColor="#E3F2FD"
                    android:fillAlpha="0.98"/>
            </group>
        </group>

        <!-- Letra S más gruesa (+5%) -->
        <group
            android:scaleX="14.30"
            android:scaleY="14.30"
            android:translateX="143.5"
            android:translateY="147.5">
            <!--
                Cambio: Aplicamos un grupo interno con escala 1.05
                para engrosar la "S" un 5% más (sin moverla)
            -->
            <group android:scaleX="1.05" android:scaleY="1.05">
                <path
                    android:fillColor="#002060"
                    android:pathData="M10,18
                          c-2.21,0 -4,-1.79 -4,-4h2
                          c0,1.1 0.9,2 2,2
                          s2,-0.9 2,-2
                          s-0.9,-2 -2,-2
                          c-2.21,0 -4,-1.79 -4,-4
                          s1.79,-4 4,-4
                          c2.21,0 4,1.79 4,4h-2
                          c0,-1.1 -0.9,-2 -2,-2
                          s-2,0.9 -2,2
                          s0.9,2 2,2
                          c2.21,0 4,1.79 4,4
                          s-1.79,4 -4,4z"/>
            </group>
        </group>

        <!-- Signo + más grueso (+5% strokeWidth) -->
        <group
            android:translateX="339"
            android:translateY="181"
            android:rotation="5.7">
            <!--
                Cambio: strokeWidth de 23.4 -> 24.6 (x1.05)
                strokeWidth de 15.6 -> 16.4 (x1.05)
            -->
            <path android:pathData="M-26,0 L26,0 M0,-26 L0,26"
                android:strokeColor="#006400"
                android:strokeWidth="24.6"
                android:strokeLineCap="round"
                android:strokeAlpha="0.36"/>

            <path android:pathData="M-26,0 L26,0 M0,-26 L0,26"
                android:strokeColor="#009900"
                android:strokeWidth="16.4"
                android:strokeLineCap="round"/>
        </group>
    </group>
</vector>
