<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base de madera más oscura -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="15dp"/>
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#A0522D"
                android:centerColor="#8B4513"
                android:endColor="#704214" />
        </shape>
    </item>

    <!-- Vetas de madera horizontales -->
    <item android:top="8dp" android:bottom="45dp">
        <shape android:shape="rectangle">
            <solid android:color="#22000000"/>
            <corners android:radius="1dp"/>
        </shape>
    </item>

    <item android:top="35dp" android:bottom="18dp">
        <shape android:shape="rectangle">
            <solid android:color="#22000000"/>
            <corners android:radius="1dp"/>
        </shape>
    </item>

    <!-- Sombra interna superior -->
    <item android:bottom="50dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#33000000"
                android:endColor="#00000000"/>
            <corners android:radius="15dp"/>
        </shape>
    </item>

    <!-- Sombra interna inferior -->
    <item android:top="50dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#33000000"
                android:endColor="#00000000"/>
            <corners android:radius="15dp"/>
        </shape>
    </item>

</layer-list>