<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">


    <item>
        <shape android:shape="rectangle">
            <solid android:color="#7A4A2A"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>

    <item
        android:left="3dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp">

        <layer-list>

            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="15dp"/>
                    <gradient
                        android:startColor="#22000000"
                        android:centerColor="#00000000"
                        android:endColor="#22000000"
                        android:angle="270"/>
                </shape>
            </item>


            <item android:top="0.5dp" android:left="0.5dp" android:right="0.5dp">
                <shape android:shape="rectangle">
                    <corners android:radius="15dp"/>
                    <stroke android:width="1dp" android:color="#22FFFFFF"/>
                </shape>
            </item>


            <item android:bottom="0.5dp" android:left="0.5dp" android:right="0.5dp">
                <shape android:shape="rectangle">
                    <corners android:radius="15dp"/>
                    <stroke android:width="1dp" android:color="#22000000"/>
                </shape>
            </item>


            <item
                android:left="10dp"
                android:top="12dp"
                android:right="10dp"
                android:bottom="12dp">
                <shape android:shape="rectangle">
                    <corners android:radius="2dp"/>
                    <solid android:color="#FFFFFFFF"/>
                </shape>
            </item>
        </layer-list>
    </item>
</layer-list>
