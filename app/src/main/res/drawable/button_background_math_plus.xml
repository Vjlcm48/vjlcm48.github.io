<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:drawable="@drawable/button_frame_wood" />


    <item
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="6dp">

        <layer-list>

            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="15dp"/>
                    <gradient
                        android:type="linear"
                        android:angle="90"
                        android:startColor="@color/blue_primary_darker"
                        android:centerColor="@color/blue_primary_dark"
                        android:endColor="@color/blue_primary_darkest"/>
                </shape>
            </item>

            <item android:left="20dp" android:top="15dp" android:right="80dp" android:bottom="35dp">
                <shape android:shape="oval">
                    <solid android:color="#11FFFFFF"/>
                </shape>
            </item>

            <item android:left="60dp" android:top="25dp" android:right="30dp" android:bottom="25dp">
                <shape android:shape="oval">
                    <solid android:color="#11FFFFFF"/>
                </shape>
            </item>

            <item android:left="15dp" android:top="20dp" android:right="15dp" android:bottom="38dp">
                <shape android:shape="rectangle">
                    <solid android:color="#08FFFFFF"/>
                    <corners android:radius="1dp"/>
                </shape>
            </item>

            <item android:left="25dp" android:top="32dp" android:right="25dp" android:bottom="26dp">
                <shape android:shape="rectangle">
                    <solid android:color="#08FFFFFF"/>
                    <corners android:radius="1dp"/>
                </shape>
            </item>

        </layer-list>

    </item>

</layer-list>
